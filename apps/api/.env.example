DATABASE_URL="postgresql://edukanban:edukanban@localhost:5432/edukanban?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
PORT=4000
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"

# AI assistant.
# AI_PROVIDER="rule" — deterministic rule-based assistant, no network (default, demo-safe).
# AI_PROVIDER="llm"  — call a real LLM via an OpenAI-compatible API. Falls back to
#                      rule-based automatically if the key is missing or the request fails.
AI_PROVIDER="rule"
# Get a free key at https://console.groq.com (OpenAI-compatible).
AI_API_KEY=""
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"
AI_TIMEOUT_MS=12000
# Other OpenAI-compatible providers (just change the 3 lines above):
#   OpenRouter: AI_BASE_URL="https://openrouter.ai/api/v1"  AI_MODEL="meta-llama/llama-3.3-70b-instruct"
#   OpenAI:     AI_BASE_URL="https://api.openai.com/v1"     AI_MODEL="gpt-4o-mini"
#   Ollama:     AI_BASE_URL="http://localhost:11434/v1"     AI_MODEL="llama3.1"  AI_API_KEY="ollama"
