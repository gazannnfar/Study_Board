generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  STAROSTA
  TEACHER
  PROJECT_MANAGER
  TEAM_LEAD
  ADMIN
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Group {
  id          String    @id @default(cuid())
  name        String
  code        String    @unique
  description String
  teacherId   String?
  teacher     User?     @relation("TeacherGroups", fields: [teacherId], references: [id], onDelete: SetNull)
  users       User[]    @relation("UserGroup")
  projects    Project[]
  tasks       Task[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  passwordHash     String
  name             String
  role             Role
  avatarColor      String             @default("#2563eb")
  active           Boolean            @default(true)
  lastLoginAt      DateTime?
  groupId          String?
  group            Group?             @relation("UserGroup", fields: [groupId], references: [id], onDelete: SetNull)
  teachingGroups   Group[]            @relation("TeacherGroups")
  managedProjects  Project[]          @relation("ProjectManager")
  leadingProjects  Project[]          @relation("TeamLead")
  createdTasks     Task[]             @relation("CreatedTasks")
  assignedTasks    Task[]             @relation("AssignedTasks")
  comments         Comment[]
  notifications    Notification[]
  satisfaction     SatisfactionVote[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  managerId   String?
  manager     User?    @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  teamLeadId  String?
  teamLead    User?    @relation("TeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String
  status         TaskStatus   @default(BACKLOG)
  priority       Priority     @default(MEDIUM)
  deadline       DateTime?
  tags           String[]     @default([])
  estimatedHours Int?
  grade          Int?
  completedAt    DateTime?
  groupId        String
  group          Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  creatorId      String
  creator        User         @relation("CreatedTasks", fields: [creatorId], references: [id], onDelete: Restrict)
  assigneeId     String?
  assignee       User?        @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments       Comment[]
  notifications  Notification[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  grade     Int?
  createdAt DateTime @default(now())
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId    String?
  task      Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model SatisfactionVote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
